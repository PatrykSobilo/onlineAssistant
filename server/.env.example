# Skopiuj ten plik jako .env i wypełnij wartości:
# cp .env.example .env

# Środowisko
NODE_ENV=production
PORT=5000

# URL frontendu (domena produkcyjna)
CLIENT_URL=https://sobit.uk

# Baza danych MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=onlineassistant_user
DB_PASSWORD=ZMIEŃ_NA_SILNE_HASŁO
DB_NAME=onlineassistant_db

# JWT Secret - wygeneruj poleceniem:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ZMIEŃ_NA_LOSOWY_STRING_MIN_64_ZNAKI

# Google Gemini API Key - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TWÓJ_GEMINI_API_KEY
